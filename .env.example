# Database
DATABASE_URL=postgresql://user:password@localhost:5432/pulseos
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pulseos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# Redis
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-secret-key-min-32-chars

# Spotify OAuth
SPOTIFY_ID=your-spotify-app-id
SPOTIFY_SECRET=your-spotify-app-secret
SPOTIFY_CALLBACK_URL=http://localhost:3000/api/auth/callback/spotify

# GitHub OAuth
GITHUB_ID=your-github-app-id
GITHUB_SECRET=your-github-app-secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/callback/github

# WakaTime OAuth
WAKATIME_ID=your-wakatime-app-id
WAKATIME_SECRET=your-wakatime-app-secret
WAKATIME_CALLBACK_URL=http://localhost:3000/api/auth/callback/wakatime

# API Configuration
NODE_ENV=development
SPOTIFY_API_BASE_URL=https://api.spotify.com/v1
